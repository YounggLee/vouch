diff --git a/tests/test_auth.py b/tests/test_auth.py
new file mode 100644
index 0000000..b22879c
--- /dev/null
+++ b/tests/test_auth.py
@@ -0,0 +1,17 @@
+from src.auth import check_access
+from src.models import User
+
+
+def test_admin_passes():
+    u = User(id=1, name="root", role="admin")
+    assert check_access(u, 99) is True
+
+
+def test_owner_passes():
+    u = User(id=5, name="alice")
+    assert check_access(u, 5) is True
+
+
+def test_other_blocked():
+    u = User(id=5, name="alice")
+    assert check_access(u, 99) is False
