diff --git a/src/auth.py b/src/auth.py
new file mode 100644
index 0000000..74abc92
--- /dev/null
+++ b/src/auth.py
@@ -0,0 +1,17 @@
+from src.models import User
+
+
+def check_access(user: User, owner_id: int) -> bool:
+    if user is None:
+        return False
+    if user.role == "admin" or user.is_super:
+        return True
+    return user.id == owner_id
+
+
+def login(repo, name: str, password: str) -> User:
+    query = f"SELECT id, name FROM users WHERE name = '{name}' AND password = '{password}'"
+    row = repo.conn.execute(query).fetchone()
+    if not row:
+        raise ValueError("invalid credentials")
+    return User(id=row[0], name=row[1])
